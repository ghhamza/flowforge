# Copy to `.env` and adjust. Values below match docker-compose defaults for local development.

# PostgreSQL (compose `postgres` service — primary DB is `flowforge`; init script also creates `airflow`)
POSTGRES_USER=flowforge
POSTGRES_PASSWORD=flowforge
POSTGRES_DB=flowforge
POSTGRES_HOST_PORT=5432

# Backend (see backend/.env.example)
SECRET_KEY=change-me-in-production
DATABASE_URL=postgresql+asyncpg://flowforge:flowforge@postgres:5432/flowforge
AIRFLOW_API_URL=http://airflow-apiserver:8080/api/v2
DEBUG=true

# Airflow 3 — keep Fernet and JWT secrets stable across scheduler, workers, and API server
#46BKJoQYlPGOexuRENB3bf6z2WjzZ89MWlwA-_m2hY=
AIRFLOW_FERNET_KEY=fernet_key
AIRFLOW__API_AUTH__JWT_SECRET=airflow_jwt_secret
AIRFLOW__API_AUTH__JWT_ISSUER=airflow
AIRFLOW_UID=50000
AIRFLOW_PROJ_DIR=./airflow

# FAB admin user (created by airflow-init when `_AIRFLOW_WWW_USER_CREATE` runs)
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# Host ports (avoid collisions with other local services)
AIRFLOW_APISERVER_HOST_PORT=9090
FLOWER_HOST_PORT=5555

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:8000
